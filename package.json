{
  "name": "recipe-ui",
  "type": "module",
  "scripts": {
    "dev": "vite --config client/vite.config.ts",
    "build": "tsc --noEmit -p client/tsconfig.json && vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "server": "node server/server.js",
    "lint": "node scripts/check-line-count.js && eslint . --max-warnings=0 && tsc --noEmit -p client/tsconfig.json"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5"
  }
}
